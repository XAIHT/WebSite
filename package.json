{
  "name": "xaiht",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node18 --format=esm --external:./dist/* --packages=external --outfile=server.js",
    "preview": "astro preview",
    "astro": "astro",
    "scan": "snyk container test angelakimichellle/xaiht:latest"
  },
  "dependencies": {
    "@astrojs/node": "^9.1.0",
    "astro": "^5.16.15",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "esbuild": "^0.27.3",
    "snyk": "^1.1294.0",
    "typescript": "^5.7.3"
  }
}
