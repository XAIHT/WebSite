---
import Layout from "../../layouts/Layout.astro";
import { useTranslations } from "../../lib/i18n";

const lang = "es";
const t = useTranslations(lang);

// Check authentication
const session = Astro.cookies.get("session");
if (!session?.value) {
  return Astro.redirect(`/${lang}/login`);
}
---

<Layout title={t("panel.title")}>
  <div class="panel-container">
    <div class="panel-header">
      <h1>{t("panel.title")}</h1>
      <p>{t("panel.welcome")}, Demo User!</p>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon">📊</div>
        <div class="stat-content">
          <h3>15</h3>
          <p>{t("panel.stats.projects")}</p>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon">✅</div>
        <div class="stat-content">
          <h3>234</h3>
          <p>{t("panel.stats.tasks")}</p>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon">👥</div>
        <div class="stat-content">
          <h3>42</h3>
          <p>{t("panel.stats.team")}</p>
        </div>
      </div>
    </div>

    <div class="panel-sections">
      <div class="section-card">
        <h2>📈 {t("panel.dashboard")}</h2>
        <p>View your project analytics and performance metrics.</p>
        <div class="placeholder-chart">
          <div class="chart-bar" style="height: 60%;"></div>
          <div class="chart-bar" style="height: 80%;"></div>
          <div class="chart-bar" style="height: 45%;"></div>
          <div class="chart-bar" style="height: 95%;"></div>
          <div class="chart-bar" style="height: 70%;"></div>
        </div>
      </div>

      <div class="section-card">
        <h2>👤 {t("panel.profile")}</h2>
        <p>Manage your personal information and preferences.</p>
        <div class="profile-info">
          <div class="info-item">
            <span class="label">Email:</span>
            <span class="value">demo@xaiht.com</span>
          </div>
          <div class="info-item">
            <span class="label">Rol:</span>
            <span class="value">Investigador</span>
          </div>
          <div class="info-item">
            <span class="label">Departamento:</span>
            <span class="value">Tecnología Avanzada</span>
          </div>
        </div>
      </div>

      <div class="section-card">
        <h2>🔧 {t("panel.settings")}</h2>
        <p>Configure your account settings and preferences.</p>
        <div class="settings-options">
          <label class="setting-item">
            <input type="checkbox" checked />
            <span>Notificaciones por correo</span>
          </label>
          <label class="setting-item">
            <input type="checkbox" checked />
            <span>Actualizaciones de proyectos</span>
          </label>
          <label class="setting-item">
            <input type="checkbox" />
            <span>Correos de marketing</span>
          </label>
        </div>
      </div>

      <div class="section-card">
        <h2>📁 {t("panel.projects")}</h2>
        <p>Access your active research projects.</p>
        <ul class="project-list">
          <li>🔬 Investigación en Computación Cuántica</li>
          <li>🤖 Estudio de Ética en IA</li>
          <li>🌐 Análisis de Sistemas Distribuidos</li>
          <li>🔐 Implementación Criptográfica</li>
        </ul>
      </div>
    </div>
  </div>
</Layout>

<style>
  .panel-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .panel-header {
    margin-bottom: 2rem;
  }

  .panel-header h1 {
    font-size: 2.5rem;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .panel-header p {
    font-size: 1.125rem;
    color: var(--text-light);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .stat-card {
    background-color: var(--surface);
    padding: 1.5rem;
    border-radius: 0.5rem;
    box-shadow: var(--shadow);
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .stat-icon {
    font-size: 2.5rem;
  }

  .stat-content h3 {
    font-size: 2rem;
    color: var(--primary);
    margin-bottom: 0.25rem;
  }

  .stat-content p {
    color: var(--text-light);
    font-size: 0.875rem;
  }

  .panel-sections {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .section-card {
    background-color: var(--surface);
    padding: 2rem;
    border-radius: 0.5rem;
    box-shadow: var(--shadow);
  }

  .section-card h2 {
    font-size: 1.5rem;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .section-card > p {
    color: var(--text-light);
    margin-bottom: 1.5rem;
  }

  .placeholder-chart {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    height: 150px;
    padding: 1rem;
    background-color: var(--background);
    border-radius: 0.375rem;
  }

  .chart-bar {
    flex: 1;
    background: linear-gradient(to top, var(--primary), var(--primary-dark));
    border-radius: 0.25rem;
    transition: height 0.3s;
  }

  .profile-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .info-item {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem;
    background-color: var(--background);
    border-radius: 0.375rem;
  }

  .info-item .label {
    font-weight: 600;
    color: var(--text);
  }

  .info-item .value {
    color: var(--text-light);
  }

  .settings-options {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .setting-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    background-color: var(--background);
    border-radius: 0.375rem;
    cursor: pointer;
  }

  .setting-item input[type="checkbox"] {
    width: 1.25rem;
    height: 1.25rem;
    cursor: pointer;
  }

  .project-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .project-list li {
    padding: 0.75rem;
    background-color: var(--background);
    border-radius: 0.375rem;
    border-left: 3px solid var(--primary);
  }

  @media (max-width: 768px) {
    .panel-header h1 {
      font-size: 2rem;
    }

    .stats-grid {
      grid-template-columns: 1fr;
    }

    .panel-sections {
      grid-template-columns: 1fr;
    }
  }
</style>
