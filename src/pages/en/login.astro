---
import Layout from "../../layouts/Layout.astro";
import { useTranslations } from "../../lib/i18n";

const lang = "en";
const t = useTranslations(lang);

// Handle form submission
let error = "";
let email = "";
if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  email = formData.get("email")?.toString().trim() || "";
  const password = formData.get("password")?.toString();

  // Basic validation
  if (!email || !password) {
    error = "Invalid credentials";
  } else {
    // Email format validation
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      error = "Invalid email format";
    } else {
      // Simple demo authentication (in production, use proper authentication with hashed passwords)
      // TODO: Replace with secure password hashing (bcrypt/argon2) and database lookup
      if (email === "demo@xaiht.com" && password === "demo123") {
        // Generate cryptographically secure session ID
        const sessionId = crypto.randomUUID();

        // Set secure session cookie
        Astro.cookies.set("session", sessionId, {
          httpOnly: true,
          secure: import.meta.env.PROD,
          sameSite: "strict",
          path: "/",
          maxAge: 60 * 60 * 24, // 24 hours
        });

        return Astro.redirect(`/${lang}/panel`);
      } else {
        error = "Invalid email or password";
      }
    }
  }
}
---

<Layout title={t("login.title")}>
  <div class="login-container">
    <div class="login-card">
      <h1>{t("login.title")}</h1>
      <p class="subtitle">{t("login.subtitle")}</p>

      {error && <div class="error-message">{error}</div>}

      <form method="POST" class="login-form">
        <div class="form-group">
          <label for="email">{t("login.email")}</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            placeholder="demo@xaiht.com"
            value={email}
          />
        </div>

        <div class="form-group">
          <label for="password">{t("login.password")}</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            autocomplete="current-password"
            placeholder="demo123"
          />
        </div>

        <button type="submit" class="submit-button">{t("login.submit")}</button>
      </form>

      <div class="divider">or</div>

      <button type="button" class="google-button">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="20px" height="20px">
          <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
          <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
          <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
          <path fill="none" d="M0 0h48v48H0z"/>
        </svg>
        {t("login.google")}
      </button>

      <p class="auth-switch">
        {t("login.no_account")} <a href={`/${lang}/register`}>{t("register.submit")}</a>
      </p>
    </div>
  </div>
</Layout>

<style>
  .login-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 60vh;
    padding: 2rem;
  }

  .login-card {
    background-color: var(--surface);
    padding: 3rem;
    border-radius: 0.5rem;
    box-shadow: var(--shadow-lg);
    width: 100%;
    max-width: 450px;
  }

  h1 {
    font-size: 2rem;
    color: var(--text);
    margin-bottom: 0.5rem;
    text-align: center;
  }

  .subtitle {
    text-align: center;
    color: var(--text-light);
    margin-bottom: 2rem;
  }

  .error-message {
    background-color: var(--error);
    color: white;
    padding: 0.75rem;
    border-radius: 0.375rem;
    margin-bottom: 1.5rem;
    text-align: center;
    font-weight: 500;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  label {
    font-weight: 600;
    color: var(--text);
    font-size: 0.875rem;
  }

  input {
    padding: 0.75rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    font-size: 1rem;
    color: var(--text);
    transition: border-color 0.2s;
    background-color: var(--background);
  }

  input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  input:-webkit-autofill,
  input:-webkit-autofill:focus {
    transition: background-color 600000s 0s, color 600000s 0s;
  }

  .submit-button {
    padding: 0.875rem;
    background-color: var(--primary);
    color: white;
    border: none;
    border-radius: 0.375rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .submit-button:hover {
    background-color: var(--primary-dark);
  }

  .divider {
    display: flex;
    align-items: center;
    text-align: center;
    margin: 1.5rem 0;
    color: var(--text-light);
    font-size: 0.875rem;
  }
  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    border-bottom: 1px solid var(--border);
  }
  .divider::before {
    margin-right: 1rem;
  }
  .divider::after {
    margin-left: 1rem;
  }

  .google-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.875rem;
    background-color: var(--surface);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s, border-color 0.2s;
    width: 100%;
  }

  .google-button:hover {
    background-color: var(--background);
    border-color: #cbd5e1;
  }

  .auth-switch {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.875rem;
    color: var(--text-light);
  }

  .auth-switch a {
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
  }

  .auth-switch a:hover {
    text-decoration: underline;
  }

  .demo-info {
    text-align: center;
    font-size: 0.875rem;
    color: var(--text-light);
    padding: 1rem;
    background-color: var(--background);
    border-radius: 0.375rem;
    border: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .login-card {
      padding: 2rem;
    }
  }
</style>
